# App
APP_NAME="AI Risk Scoring Platform"
APP_VERSION=0.1.0
APP_ENV=local
APP_PORT=8000
LOG_LEVEL=INFO

# Modelo
# El binario .joblib se genera offline con: python -m app.models.train_model
MODEL_PATH=app/models/risk_model.joblib
MODEL_VERSION=v0.2.0

# PostgreSQL (S3+)
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=risk_scoring
POSTGRES_USER=risk
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+psycopg://risk:changeme@localhost:55432/risk_scoring
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5

# Batch CSV predictions (S4)
BATCH_CHUNK_SIZE=1000
BATCH_MAX_UPLOAD_BYTES=10485760

# Mensajería (S5+)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
QUEUE_PREDICTIONS=risk.predictions

# Observabilidad (S6+)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
