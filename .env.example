# App
APP_NAME="AI Risk Scoring Platform"
APP_VERSION=0.1.0
APP_ENV=local
APP_PORT=8000
LOG_LEVEL=INFO

# Modelo
MODEL_PATH=app/models/risk_model.joblib
# En S1 el scoring es mockeado. En S2 entra el modelo real (v0.2.0).
MODEL_VERSION=mock-0.1

# PostgreSQL (S3+)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=risk_scoring
POSTGRES_USER=risk
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://risk:changeme@localhost:5432/risk_scoring

# Mensajería (S5+)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
QUEUE_PREDICTIONS=risk.predictions

# Observabilidad (S6+)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
